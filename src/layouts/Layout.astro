---
import "../styles/global.css";

interface Props {
  title?: string;
  description?: string;
  lang?: string;
}

const {
  title = "memory-forge | Synthetic Archive",
  description = "memory-forge is a personal research lab and experimental web atelier.",
  lang = "ja"
} = Astro.props;
---

<!doctype html>
<html lang={lang}>
  <head>
    <meta charset="UTF-8" />
    <meta name="description" content={description} />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="generator" content={Astro.generator} />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <title>{title}</title>
  </head>
  <body>
    <slot />
  </body>
</html>
